{
  "name": "@streamdown-svelte/mermaid",
  "version": "1.0.3",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup index.ts --format esm --dts --clean",
    "prepack": "pnpm run build"
  },
  "dependencies": {
    "@streamdown-svelte/plugin-core": "workspace:*",
    "mermaid": "^11.11.0"
  },
  "description": "Standalone mermaid plugin package used by the streamdown-svelte workspace.",
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  }
}
