{
  "name": "@streamdown-svelte/code",
  "version": "1.1.3",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup index.ts --format esm --dts --clean",
    "prepack": "pnpm run build"
  },
  "dependencies": {
    "@streamdown-svelte/plugin-core": "workspace:*",
    "shiki": "^3.13.0"
  },
  "description": "Standalone code highlighter plugin package for the streamdown-svelte workspace.",
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  }
}
