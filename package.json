{
	"name": "svelte-streamdown",
	"version": "3.0.1",
	"scripts": {
		"dev": "vite dev",
		"build": "pnpm build:packages && vite build && pnpm package:root",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"prepack": "pnpm build:packages && pnpm package:root",
		"check": "pnpm build:packages && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "pnpm build:packages && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check .",
		"test:ui": "vitest --ui",
		"test:unit": "vitest --reporter=dot --silent=passed-only",
		"test:coverage": "node scripts/coverage-report.mjs",
		"test:coverage:parser": "node scripts/coverage-report.mjs parser",
		"test:coverage:components": "node scripts/coverage-report.mjs components",
		"test:coverage:parity": "node scripts/coverage-report.mjs parity",
		"test:contracts": "vitest --reporter=dot --silent=passed-only --run tests/contracts/*.spec.ts",
		"test:playwright:parity": "playwright test tests/playwright/parity --reporter=dot --quiet",
		"test": "npm run test:unit -- --run",
		"docs:test-migration-status": "node scripts/test-migration-status.mjs --write",
		"verify:test-migration-status": "node scripts/test-migration-status.mjs --check",
		"verify:pack": "node scripts/verify-pack.mjs",
		"verify:exports": "node scripts/verify-exports.mjs",
		"snapshot:reference-api-surface": "node scripts/reference-api-surface.mjs --write",
		"verify:reference-api-surface": "node scripts/reference-api-surface.mjs --check",
		"snapshot:local-api-surface": "node scripts/local-api-surface.mjs --write",
		"verify:local-api-surface": "node scripts/local-api-surface.mjs --check",
		"verify:api-surface": "pnpm verify:reference-api-surface && pnpm verify:local-api-surface && pnpm test:contracts",
		"verify:toolchain": "node scripts/verify-toolchain.mjs",
		"verify:clean-build": "node scripts/verify-clean-build.mjs",
		"verify:dependency-policy": "node scripts/verify-dependency-policy.mjs",
		"release:metadata": "node scripts/release-metadata.mjs",
		"verify:release-metadata": "node scripts/verify-release-metadata.mjs",
		"build:packages": "pnpm -r --filter './packages/*' build",
		"package:root": "svelte-kit sync && svelte-package && publint",
		"verify:workspace-smoke": "node scripts/verify-workspace-smoke.mjs"
	},
	"files": [
		"dist",
		"!dist/**/*.test.*",
		"!dist/**/*.spec.*"
	],
	"sideEffects": [
		"**/*.css"
	],
	"svelte": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"svelte": "./dist/index.js"
		},
		"./code": {
			"types": "./dist/Elements/Code.svelte.d.ts",
			"svelte": "./dist/Elements/Code.svelte"
		},
		"./detect-direction": {
			"types": "./dist/detect-direction.d.ts",
			"import": "./dist/detect-direction.js"
		},
		"./icon-context": {
			"types": "./dist/icon-context.d.ts",
			"import": "./dist/icon-context.js"
		},
		"./math": {
			"types": "./dist/Elements/Math.svelte.d.ts",
			"svelte": "./dist/Elements/Math.svelte"
		},
		"./mermaid": {
			"types": "./dist/Elements/Mermaid.svelte.d.ts",
			"svelte": "./dist/Elements/Mermaid.svelte"
		},
		"./plugin-context": {
			"types": "./dist/plugin-context.d.ts",
			"import": "./dist/plugin-context.js"
		},
		"./plugins": {
			"types": "./dist/plugins.d.ts",
			"import": "./dist/plugins.js"
		},
		"./remend": {
			"types": "./dist/remend.d.ts",
			"import": "./dist/remend.js"
		},
		"./url-policy": {
			"types": "./dist/url-policy.d.ts",
			"import": "./dist/url-policy.js"
		},
		"./utils": {
			"types": "./dist/utils/index.d.ts",
			"import": "./dist/utils/index.js"
		}
	},
	"peerDependencies": {
		"svelte": "^5.0.0"
	},
	"devDependencies": {
		"@cloudflare/workers-types": "^4.20250906.0",
		"@playwright/test": "^1.55.0",
		"@sveltejs/adapter-cloudflare": "^7.0.0",
		"@sveltejs/kit": "^2.22.0",
		"@sveltejs/package": "^2.0.0",
		"@sveltejs/vite-plugin-svelte": "^6.0.0",
		"@tailwindcss/vite": "^4.0.0",
		"@types/mdast": "^4.0.4",
		"@types/node": "^24.6.1",
		"@types/pngjs": "^6.0.5",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^5.1.2",
		"@vitest/browser": "^3.2.3",
		"@vitest/coverage-v8": "^3.2.3",
		"@vitest/ui": "^3.2.4",
		"hast-util-to-jsx-runtime": "^2.3.6",
		"html-url-attributes": "^3.0.1",
		"pixelmatch": "^7.1.0",
		"playwright": "^1.53.0",
		"pngjs": "^7.0.0",
		"prettier": "^3.4.2",
		"prettier-plugin-svelte": "^3.3.3",
		"prettier-plugin-tailwindcss": "^0.6.11",
		"publint": "^0.3.2",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"rehype-katex": "^7.0.1",
		"remark-cjk-friendly": "^2.0.1",
		"remark-cjk-friendly-gfm-strikethrough": "^2.0.1",
		"remark-math": "^6.0.0",
		"stick-to-bottom-svelte": "^1.0.1",
		"svelte": "^5.0.0",
		"svelte-check": "^4.0.0",
		"svelte-themes": "^2.0.8",
		"tailwindcss": "^4.0.0",
		"typescript": "^5.0.0",
		"unist-util-visit": "^5.1.0",
		"unist-util-visit-parents": "^6.0.2",
		"vite": "^7.0.4",
		"vite-plugin-devtools-json": "^1.0.0",
		"vitest": "^3.2.3",
		"vitest-browser-svelte": "^0.1.0",
		"wrangler": "^4.34.0",
		"@streamdown/cjk": "workspace:*",
		"@streamdown/code": "workspace:*",
		"@streamdown/math": "workspace:*",
		"@streamdown/mermaid": "workspace:*",
		"@types/unist": "^3.0.3",
		"remark-stringify": "^11.0.0",
		"tsup": "^8.5.0"
	},
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/BetterAndBetterII/svelte-streamdown.git"
	},
	"keywords": [
		"svelte"
	],
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild"
		]
	},
	"dependencies": {
		"@floating-ui/dom": "^1.7.4",
		"@shikijs/langs": "^3.17.1",
		"@shikijs/themes": "^3.17.1",
		"clsx": "^2.1.1",
		"katex": "^0.16.22",
		"marked": "^16.2.1",
		"mermaid": "^11.11.0",
		"rehype-harden": "^1.1.8",
		"rehype-raw": "^7.0.0",
		"rehype-sanitize": "^6.0.0",
		"rehype-stringify": "^10.0.1",
		"remark-gfm": "^4.0.1",
		"remark-parse": "^11.0.0",
		"remark-rehype": "^11.1.2",
		"shiki": "^3.13.0",
		"tailwind-merge": "^3.3.1",
		"unified": "^11.0.5",
		"remend": "workspace:*"
	},
	"packageManager": "pnpm@10.32.1",
	"volta": {
		"node": "22.22.1",
		"pnpm": "10.32.1"
	}
}
